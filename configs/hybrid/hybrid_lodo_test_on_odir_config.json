{
  "seed": 42,
  "method": "DGA-DG",
  "description": "Discriminator-Guided Adaptive Domain Generalisation",
  "novelty": "\u03b1(t)=sigmoid(K\u00d7(d_acc-0.5)) jointly controls \u03bb_DANN, \u03bb_mix, \u03b7_DRO",
  "test_domain": "ODIR",
  "train_domains": "RFMiD_v1 + RFMiD_v2",
  "val_strategy": "RFMiD_v2_val (OOD proxy)",
  "model": "ResNet50 (layer1+layer2 frozen)",
  "head": "2048->256->4",
  "discriminator": "GRL->Linear(2048,256)->ReLU->LayerNorm->Linear(256,2)",
  "dropout": 0.5,
  "weight_decay": 0.0005,
  "loss": "FocalBCE(q-weighted) + \u03bb_DANN(t)\u00d7DANN + Mixup(\u03bb_mix(t))",
  "scheduler": "LinearWarmup(5ep)+CosineAnnealing",
  "pos_weight": "per-domain averaged",
  "threshold": "fixed 0.5",
  "dann_max": 1.0,
  "mixup_alpha_max": 0.4,
  "base_eta": 0.01,
  "sigmoid_k": 10.0,
  "d_acc_ema": 0.95,
  "dann_lr_mult": 10.0
