  "pos_weight": "per-domain averaged",
  "threshold": "fixed 0.5",
  "coral_lambda": 1.0,
  "coral_feature_dim": 2048,
  "note": "CORAL penalty at backbone output (2048-dim). Per-domain loaders with drop_last=True."
